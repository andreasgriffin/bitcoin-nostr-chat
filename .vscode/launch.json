    {
      "name": "Pytest",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-vvv",
        "--log-cli-level=0"
      ],
      "console": "integratedTerminal"
    }, {
      "name": "Pytest: Current File",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-vvv",
        "${file}",
        "-o", "log_cli=true",
        "-o", "log_cli_level=DEBUG",
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },{
      "name": "Pytest: Check preferred relays",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-vvv",
        "-o", "log_cli=true",
        "-o", "log_cli_level=INFO",
        "--preferred_relays"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },{
      "name": "Pytest: Check relays",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-vvv",
        "-o", "log_cli=true",
        "-o", "log_cli_level=INFO",
        "--testrelays"
      ],
